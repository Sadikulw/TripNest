<% layout("/layouts/boilerplate") %>
<div class="container py-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Image -->
        <img src="<%= listing.image.url %>" class="card-img-top object-fit-cover" style="height: 420px;" alt="<%= listing.title %>">

        <!-- Body -->
        <div class="card-body p-4">

          <!-- Title -->
          <h2 class="fw-bold mb-3"><%= listing.title %></h2>
          <p class="text-muted mb-3">
            <i class="fa fa-user text-danger me-1"></i>
            <%= listing.owner && listing.owner.username ? listing.owner.username : "Guest" %>
          </p>
          <!-- Location Badge -->
          <p class="text-muted mb-3">
            <i class="fa fa-map-marker-alt text-danger me-1"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>

          <!-- Price -->
          <h4 class="text-primary fw-bold mb-4">
            ₹ <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "0" %>
            <span class="fs-6 text-muted">/ night</span>
          </h4>

          <!-- Description -->
          <p class="mb-4 text-secondary" style="line-height: 1.7;">
            <%= listing.description %>
          </p>
          <% if (currentUser && listing.owner && currentUser._id.toString() === listing.owner._id.toString()) { %>

          <!-- Buttons -->
          <div class="d-flex gap-3">

            <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary px-4 rounded-pill">
              <i class="fa fa-edit me-1"></i> Edit
            </a>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
              <button class="btn btn-outline-danger px-4 rounded-pill" onclick="return confirm('Are you sure you want to delete this listing?')">
                <i class="fa fa-trash me-1"></i> Delete
              </button>
            </form>

          </div>

          <% } %>


        </div>
      </div>

    </div>
  </div>
</div>
<div class="container mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <div class="card border-0 rounded-4 p-5" style="box-shadow: 0 6px 20px rgba(0,0,0,0.06);">
        <% if(currentUser){ %>
        <h4 class="fw-semibold mb-4" style="letter-spacing: 0.5px;">
          Leave a Review
        </h4>

        <form action="/listings/<%= listing._id %>/reviews" method="post">

          <!-- Rating -->
          <!-- Star Rating -->
          <div class="mb-4">
            <!-- <label class="form-label fw-medium mb-2">Rating</label> -->

            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />

              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>

              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>

              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>

              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>

              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>

          </div>
          <!-- Comment -->
          <div class="mb-4">
            <label class="form-label fw-medium mb-2">Comment</label>
            <textarea name="review[comment]" rows="4" class="form-control border-2 rounded-4 p-3" placeholder="Share your experience..." style="border-color: #e0e0e0;"></textarea>
          </div>

          <!-- Button -->
          <button class="btn text-white px-4 py-2 rounded-pill fw-medium" style="background-color: #FF385C; border: none;">
            Submit Review
          </button>

        </form>
        <%}%>
        <div>
          <div class="mt-5">
            <h4 class="fw-bold mb-4">Reviews</h4>

            <% if(listing.reviews.length === 0){ %>
        <p class="text-muted">No reviews yet</p>
        <% } else { %>

        <div class="row g-4">
          <% for(let review of listing.reviews){ %>

          <div class="col-md-6">
            <div class="border rounded-4 p-3 position-relative">
              <% if (currentUser && review.author && currentUser._id.toString() === review.author._id.toString()) { %>
              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="position-absolute top-0 end-0 m-2">
                <button class="btn btn-sm btn-light border-0" onclick="return confirm('Delete this review?')">
                  ✕
                </button>
              </form>
              <% } %>


              <!-- Avatar + Name -->
              <div class="d-flex align-items-center mb-2">
                <div class="rounded-circle bg-dark text-white d-flex justify-content-center align-items-center" style="width:40px; height:40px; font-size:14px;">
                  <%= review.author.username[0] %>
                </div>

                <div class="ms-3">
                  <h6 class="mb-0 fw-semibold"><%= review.author.username %></h6>
                  <small class="text-muted">Recent stay</small>
                </div>
              </div>

              <!-- Stars -->
              <div class="mb-2 text-danger" style="font-size:14px;">
                <% for(let i = 1; i <= 5; i++){ %>
                <% if(i <= review.rating){ %>
                ★
                <% } else { %>
                <span class="text-secondary">★</span>
                <% } %>
                <% } %>
              </div>

              <!-- Comment -->
              <p class="mb-0 text-dark" style="font-size:15px; line-height:1.6;">
                <%= review.comment %>
              </p>

            </div>
          </div>

          <% } %>
        </div>

        <% } %>
      </div>
    </div>
  </div>

</div>
</div>
</div>
<!-- Map Section -->
<div class="container mb-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <div class="card border-0 shadow rounded-4 overflow-hidden">

      <div class="card-body pb-2">

  <h5 class="fw-bold mb-1">
    Where you’ll be
  </h5>

  <p class="text-secondary small">
    <i class="fa fa-map-marker-alt text-danger me-1"></i>
    <%= listing.location %>, <%= listing.country %>
  </p>

</div>
        <!-- Map -->
        <div id="map" style="height:400px;"></div>

      </div>

    </div>
  </div>
</div>
<script>
  const mapToken = "<%= mapToken %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
  const listingTitle = "<%= listing.title %>";
  const listingLocation = "<%= listing.location %>";
</script>
<script src="/js/map.js"></script>