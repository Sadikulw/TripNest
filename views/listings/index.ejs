<% layout("/layouts/boilerplate") %>

<div class="container my-5">

  <h2 class="fw-bold text-center mb-5 mt-5">Explore Stays</h2>

  <div class="row g-4">
    <% for (let listing of listings) { %>
      <div class="col-12 col-sm-6 col-md-4 col-lg-3">

        <div class="card listing-card h-100 position-relative">

          <img 
            src="<%= listing.image %>" 
            class="card-img-top listing-img" 
            alt="<%= listing.title %>"
          >

          <div class="card-body">
            <h5 class="card-title fw-semibold mb-2">
              <%= listing.title %>
            </h5>
<p class="price mb-0">
  ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
  <span>/ night</span>
</p>


            <!-- whole card clickable -->
            <a href="/listings/<%= listing._id %>" class="stretched-link"></a>
          </div>

        </div>

      </div>
    <% } %>
  </div>

</div>
