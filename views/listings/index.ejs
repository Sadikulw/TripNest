<% layout("/layouts/boilerplate") %>

<div class="container my-4">

  <!-- Category Filter Bar -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">

    <!-- Categories -->
    <div class="d-flex flex-nowrap overflow-auto gap-5 category-scroll">

      <div class="category-item">
        <a href="/listings" class="category-link">
          <i class="fa-solid fa-fire"></i>
          <p>Trending</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=Rooms" class="category-link">
          <i class="fa-solid fa-bed"></i>
          <p>Rooms</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=Beach" class="category-link">
          <i class="fa-solid fa-umbrella-beach"></i>
          <p>Beach</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=Farms" class="category-link">
          <i class="fa-solid fa-tractor"></i>
          <p>Farms</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=Amazing-Pools" class="category-link">
          <i class="fa-solid fa-person-swimming"></i>
          <p>Amazing Pools</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=OMG" class="category-link">
          <i class="fa-solid fa-bolt"></i>
          <p>OMG!</p>
        </a>
      </div>

      <div class="category-item">
        <a href="/listings?category=Amazing-Views" class="category-link">
          <i class="fa-solid fa-image"></i>
          <p>Amazing Views</p>
        </a>
      </div>

    </div>
<div class="dropdown">
  <button 
    class="btn btn-outline-dark rounded-pill px-3 dropdown-toggle"
    type="button"
    data-bs-toggle="dropdown"
    aria-expanded="false"
  >
    <i class="fa-solid fa-sliders"></i> Filter
  </button>

  <ul class="dropdown-menu">
    <li>
      <a class="dropdown-item" href="/listings?filters=low-to-High">
        Low to High
      </a>
    </li>

    <li>
      <a class="dropdown-item" href="/listings?filters=high-to-low">
        High to Low
      </a>
    </li>

    <li>
      <a class="dropdown-item" href="/listings?filters=normal">
        Normal
      </a>
    </li>
  </ul>
</div>
    <!-- Tax Toggle -->
    <div class="tax-toggle d-flex align-items-center gap-2 px-3 py-2 border rounded-pill">

      <span class="fw-semibold small tax-text">
        Display total before taxes
      </span>

      <div class="form-check form-switch m-0">
        <input class="form-check-input" type="checkbox" id="taxToggle">
      </div>

    </div>

  </div>


  <!-- Listings -->
  <div class="row g-4">

    <% for (let listing of listings) { %>

    <div class="col-12 col-sm-6 col-md-4 col-lg-3">

      <div class="card listing-card h-100 border-0 shadow-sm">

        <img src="<%= listing.image.url %>" class="card-img-top listing-img" alt="<%= listing.title %>">

        <div class="card-body">

          <h6 class="card-title fw-semibold mb-2 text-truncate">
            <%= listing.title %>
          </h6>

          <p class="price mb-0">

            <span class="price-value" data-price="<%= listing.price %>">
              ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
            </span>

            <span>/ night</span>

            <span class="tax-info text-muted small">
              +18% tax
            </span>

          </p>

          <a href="/listings/<%= listing._id %>" class="stretched-link"></a>

        </div>

      </div>

    </div>

    <% } %>

  </div>

</div>

<script src="/js/script.js"></script>